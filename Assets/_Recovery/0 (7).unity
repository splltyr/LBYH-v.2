--- !u!114 &1521517747
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1521517746}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d657f1880db04f741b7f16aaa8ea2e77, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Scene6SequenceController
  dialogue: {fileID: 279881359}
  introLines:
  - name: Yves
    text: Ugh, How's my luck worse than this?
    voiceClip: {fileID: 0}
  - name: Tala
    text: Good thing that I don't have legs.
    voiceClip: {fileID: 0}
  - name: Tala
    text: Yves 0, Tala 1. Muehehehe
    voiceClip: {fileID: 0}
  - name: Yves
    text: I didn't know that your name is Tala.
    voiceClip: {fileID: 0}
  - name: Tala
    text: Well, I never really got the chance to introduce myself.
    voiceClip: {fileID: 0}
  - name: Yves
    text: Hmm.. Who exactly are you?
    voiceClip: {fileID: 0}
  - name: Tala
    text: Glad you asked, even if it's late. Haloo! I am Tala, I am a spirit that
      roams around here in this world.
    voiceClip: {fileID: 0}
  - name: Yves
    text: Purpose, huh? Your purpose is to be a glowy bubble that chatters a lot?
    voiceClip: {fileID: 0}
  - name: Tala
    text: HEY! But really, my purpose is to guide y-
    voiceClip: {fileID: 0}
  - name: Narrative
    text: '[Some Sneaks and Mechanics have appeared. Suddenly a male voice calls
      for help.]'
    voiceClip: {fileID: 0}
  - name: Male Voice
    text: I swear on every deity. If you don- AGH!
    voiceClip: {fileID: 0}
  - name: Tala
    text: '*sighs* Aaand my words get cut off again.. That way, Yves!'
    voiceClip: {fileID: 0}
  - name: Yves
    text: Let's go!
    voiceClip: {fileID: 0}
  meetDaveLines:
  - name: Yves
    text: Are you hurt?
    voiceClip: {fileID: 0}
  - name: ???
    text: What deity are you to save me, young man?
    voiceClip: {fileID: 0}
  - name: Tala
    text: Wow, Yves? A deity? He's funny.
    voiceClip: {fileID: 0}
  - name: Yves
    text: Uh.. I am no deity, Sir..?
    voiceClip: {fileID: 0}
  - name: Sir Dave
    text: Ah, apologies.. My name is Dave, I was once a Professor here on STI.
    voiceClip: {fileID: 0}
  - name: Yves
    text: Sir Dave? Oh, Sir Rome told me that you might be able to help me..
    voiceClip: {fileID: 0}
  - name: Sir Dave
    text: Correct. I can upgrade your weapons and make you even stronger.
    voiceClip: {fileID: 0}
  - name: Tala
    text: That would be awesome!
    voiceClip: {fileID: 0}
  - name: Sir Dave
    text: May I ask if Reya and Rome are doing fine?
    voiceClip: {fileID: 0}
  - name: Yves
    text: Yes, Sir Dave. I made sure that they're safe before coming here.
    voiceClip: {fileID: 0}
  - name: Sir Dave
    text: So that would mean that you have defeated the Corrupted's, yes?
    voiceClip: {fileID: 0}
  - name: Yves
    text: Uh.. Yes sir.
    voiceClip: {fileID: 0}
  - name: Tala
    text: It's almost like an interview..
    voiceClip: {fileID: 0}
  - name: Sir Dave
    text: Let me see what I can do for you.
    voiceClip: {fileID: 0}
  - name: Narrative
    text: '[Sir Dave prepares his tools. Yves upgrades his weapons.]'
    voiceClip: {fileID: 0}
  bossSpawnLines:
  - name: Narrative
    text: '[The lights flicker. The sewer water ripples violently.]'
    voiceClip: {fileID: 0}
  - name: Yves
    text: That doesn't smell good.
    voiceClip: {fileID: 0}
  - name: Tala
    text: That doesn't look good.
    voiceClip: {fileID: 0}
  - name: Sir Dave
    text: Kid... get ready. That's not just movement... that's the boss!
    voiceClip: {fileID: 0}
  - name: Corrupted Janitor
    text: CLLLEEEAAANNN... EVERTHING MUST BE CLEAN... FOR MASTER [REDACTED]!
    voiceClip: {fileID: 0}
  - name: Yves
    text: Yeah... definitely corrupted... A Weird looking ONE!?
    voiceClip: {fileID: 0}
  - name: Tala
    text: "Be careful! He charges fast\u2014wait for the right moment!"
    voiceClip: {fileID: 0}
  bossEndLines:
  - name: Janitor
    text: W-Where's my d-daughter.. Aghh! it hurts..
    voiceClip: {fileID: 0}
  - name: Yves
    text: Sir Dave, please help!
    voiceClip: {fileID: 0}
  - name: Sir Dave
    text: I'll take him somewhere safe. You keep moving, kid.
    voiceClip: {fileID: 0}
  - name: Yves
    text: Hey Tala, how come this one had a person inside?
    voiceClip: {fileID: 0}
  - name: Tala
    text: His body was corrupted, but his soul was pure. Let's focus on what's ahead.
    voiceClip: {fileID: 0}
  firstWaveEnemies: {fileID: 0}
  firstWaveSpawnPoint: {fileID: 0}
  janitorBoss: {fileID: 0}
  bossSpawnPoint: {fileID: 0}
