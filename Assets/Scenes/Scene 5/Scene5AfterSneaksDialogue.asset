  lines:
  - name: ???
    text: Good job, Yves!
    voiceClip: {fileID: 0}
  - name: ???
    text: Look, there! That's the Lab.
    voiceClip: {fileID: 0}
  - name: Yves
    text: "Yeah.. I don\u2019t think there\u2019s a key for this floor."
    voiceClip: {fileID: 0}
  - name: Yves and Tala
    text: "\u201CBeware of the gate\u2026 If you solve this Pathfinding Maze you
      may seek the floor you go to but there will be a Guardian\u2026\u201D"
    voiceClip: {fileID: 0}
  - name: ???
    text: "There\u2019s a Guardian now?!"
    voiceClip: {fileID: 0}
  - name: Yves
    text: I thought you knew everything about this place?
    voiceClip: {fileID: 0}
  - name: ???
    text: Uh.. No, I didn't..
    voiceClip: {fileID: 0}
  - name: ???
    text: Yves, take a look!
    voiceClip: {fileID: 0}
  - name: Yves
    text: No other options, I must go forward to it.
    voiceClip: {fileID: 0}
  - name: ???
    text: "Do you know that you\u2019re bad at this?"
    voiceClip: {fileID: 0}
  - name: Yves
    text: "I\u2019m no expert, I did my best! That took me about 30 minutes!"
    voiceClip: {fileID: 0}
