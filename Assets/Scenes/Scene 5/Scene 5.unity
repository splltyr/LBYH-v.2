--- !u!114 &798111916
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 798111915}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a68766d91b8a462449c9033c8ffdbbec, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Scene5SequenceController
  dialogue: {fileID: 745747979}
  puzzle: {fileID: 0}
  fadeOverlay: {fileID: 0}
  nextSceneName: Scene 6
  bgmClip: {fileID: 8300000, guid: 8460a98aaecc8a04abed9218b92143a2, type: 3}
  bgmVolume: 0.119
  player: {fileID: 1705635088}
  sneaksGroup: {fileID: 228884166}
  puzzleTabletTrigger: {fileID: 0}
  doorTeleportTrigger: {fileID: 614959029}
  bullyArenaTeleportPoint: {fileID: 829430061}
  bullyBoss: {fileID: 555300203}
  introLines:
  - name: Yves
    text: Ugh why is this floor so creepy.. And dang it stinks. . .
    voiceClip: {fileID: 8300000, guid: 6fc899724b7adbc4eaefa50f5217b244, type: 3}
    volume: 1
  - name: Tala
    text: Jeez.. The smell makes me wanna disappear.
    voiceClip: {fileID: 8300000, guid: 93d0aff7262f4c64590d57397ee1324d, type: 3}
    volume: 1
  - name: Yves
    text: "Aren\u2019t you a spirit?"
    voiceClip: {fileID: 8300000, guid: fc34dab76dce3bc49846863602c7cc17, type: 3}
    volume: 1
  - name: Tala
    text: Oh..
    voiceClip: {fileID: 0}
    volume: 1
  ambushLines:
  - name: Tala
    text: YVES! THE CEILING! WATCH OU-
    voiceClip: {fileID: 8300000, guid: 5935a7107abcd6d46916415a16c7c6f3, type: 3}
    volume: 1
  - name: Yves
    text: Huh..?
    voiceClip: {fileID: 8300000, guid: 9584baaddc6afbe4899a46aaad00d20a, type: 3}
    volume: 1
  postAmbushLines:
  - name: Yves
    text: "So this is what Sir Rome is talking about? What is it called\u2026 Ah,
      Sneaks. "
    voiceClip: {fileID: 8300000, guid: 51fd94fd5ba3f964a9c79d89bf8ec6b3, type: 3}
    volume: 1
  - name: Tala
    text: Good job, Yves!
    voiceClip: {fileID: 8300000, guid: 7862ba5b75ca2684c8c3735644847644, type: 3}
    volume: 1
  - name: Tala
    text: Look, there! That's the Lab.
    voiceClip: {fileID: 8300000, guid: 204bb2626d1260940add6b2f0be66615, type: 3}
    volume: 1
  doorLockedLines:
  - name: Yves
    text: "Yeah.. I don\u2019t think there\u2019s a key for this floor."
    voiceClip: {fileID: 8300000, guid: bb2acebd3a569064dafd30f17a34c21b, type: 3}
    volume: 1
  noteLines:
  - name: Narrative
    text: "\u201CBeware of the gate\u2026 If you solve this Pathfinding Maze you
      may seek the floor you go to but there will be a Guardian\u2026\u201D"
    voiceClip: {fileID: 0}
    volume: 1
  - name: Tala
    text: "There\u2019s a Guardian now?!"
    voiceClip: {fileID: 8300000, guid: 5a4e8c5067c29054d811f40dd98729d0, type: 3}
    volume: 1
  - name: Yves
    text: I thought you knew everything about this place?
    voiceClip: {fileID: 8300000, guid: 50770405eb9e3064ba3c476f015dfdf1, type: 3}
    volume: 1
  - name: Tala
    text: 'Uh.. No, I didn''t.. '
    voiceClip: {fileID: 8300000, guid: ae470fcfb6cba864daac903d1838020f, type: 3}
    volume: 1
  postNoteLines:
  - name: Tala
    text: Yves, take a look!
    voiceClip: {fileID: 8300000, guid: 772d31a2bc441e44596f84687744c4ba, type: 3}
    volume: 1
  - name: Yves
    text: No other options, I must go forward to it.
    voiceClip: {fileID: 8300000, guid: 5c0d631ab644755408018bdd2f318cd7, type: 3}
    volume: 1
  postPuzzleLines:
  - name: Tala
    text: "Do you know that you\u2019re bad at this?"
    voiceClip: {fileID: 8300000, guid: 1d458e95f9dc34c458fb27154e4299ed, type: 3}
    volume: 1
  - name: Yves
    text: "I\u2019m no expert, I did my best! That took me about 30 minutes! "
    voiceClip: {fileID: 0}
    volume: 1
  - name: Tala
    text: "Now let\u2019s see what\u2019s in here."
    voiceClip: {fileID: 8300000, guid: 4549faa34dc1b2846a03b8c1075a93d4, type: 3}
    volume: 1
  bullyIntroLines:
  - name: Yves
    text: "What the\u2026"
    voiceClip: {fileID: 8300000, guid: 621a0b9c6c65a1a4d8571dc4f3ee01e8, type: 3}
    volume: 1
  - name: Tala
    text: "That doesn\u2019t look good.."
    voiceClip: {fileID: 0}
    volume: 1
  - name: Tala
    text: Yves! On your left!
    voiceClip: {fileID: 8300000, guid: 75710b634a2ef284ca79b8d641d00624, type: 3}
    volume: 1
  - name: Yves
    text: So you're the one who keeps the corrupted in bay.
    voiceClip: {fileID: 0}
    volume: 1
  - name: Yves
    text: "A\u2026Bully?"
    voiceClip: {fileID: 8300000, guid: 02775b5345f04ea498efc0b4cc982127, type: 3}
    volume: 1
  bullyMidFightLines:
  - name: School Bully
    text: "Clever, Brat. But you won\u2019t be going up and saving the others of
      how many My corrupted digitals are forming when I kill you!"
    voiceClip: {fileID: 0}
    volume: 1
  - name: Yves
    text: "I won\u2019t let you HURT THEM!"
    voiceClip: {fileID: 8300000, guid: f922673388ad416449186589aa2ccd46, type: 3}
    volume: 1
  - name: Tala
    text: Yeah! That's the spirit! Oh wait, I am a spirit..
    voiceClip: {fileID: 8300000, guid: 4c6999769e9177041a1203d5a0ed7d4d, type: 3}
    volume: 1
  bullyMidFight2Lines:
  - name: School Bully
    text: Stop acting like a brat!
    voiceClip: {fileID: 0}
    volume: 1
  - name: Tala
    text: Is he.. talking to a mirror or something..?
    voiceClip: {fileID: 8300000, guid: a3f2438421929824a98f01eef5df0ede, type: 3}
    volume: 1
  victoryLines:
  - name: Yves
    text: "Who\u2019s a brat now?"
    voiceClip: {fileID: 8300000, guid: 5cd539c8e13c2484c81b4bd3756a5515, type: 3}
    volume: 1
  - name: Tala
    text: If only our guidance counselors were here.. They will never let this idiot
      in.
    voiceClip: {fileID: 8300000, guid: 1dc4a4fb4a6fc6b4b87e757be0d3f11b, type: 3}
    volume: 1
  - name: Yves
    text: "Hey, that\u2019s not nice."
    voiceClip: {fileID: 8300000, guid: 3b44836388c99fd43a6c0f00b0e0110a, type: 3}
    volume: 1
  - name: Tala
    text: Hmph! You look terrible.
    voiceClip: {fileID: 8300000, guid: c23a5c8fd322b34489517b72835ae70a, type: 3}
    volume: 1
  - name: Yves
    text: "I\u2019ll wipe it off. Look, there\u2019s an elevator."
    voiceClip: {fileID: 8300000, guid: 8fda1ab69c8b76a4bb67f463c0c878f3, type: 3}
    volume: 1
