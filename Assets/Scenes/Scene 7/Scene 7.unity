--- !u!114 &179664165
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 179664164}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b17d9370082805d4d971cfc25ac5ab1a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Scene7SequenceController
  dialogue: {fileID: 613966160}
  nextSceneName: Scene 8
  introLines:
  - name: Tala
    text: This place.. I remember things as if they were just yesterday.
    voiceClip: {fileID: 0}
    volume: 1
  - name: Yves
    text: Have you been on this floor?
    voiceClip: {fileID: 0}
    volume: 1
  - name: Tala
    text: More than you can imagine.
    voiceClip: {fileID: 0}
    volume: 1
  - name: Narrative
    text: '[Glitch enemies begin forming from computer parts.]'
    voiceClip: {fileID: 0}
    volume: 1
  - name: Yves
    text: "So this is where things get worse\u2026"
    voiceClip: {fileID: 0}
    volume: 1
  postFirstFightLines:
  - name: Yves
    text: "That was tough.. Let\u2019s get moving, Tala."
    voiceClip: {fileID: 0}
    volume: 1
  - name: Tala
    text: May you guys rest, in peace.
    voiceClip: {fileID: 0}
    volume: 1
  misArrivalLines:
  - name: Narrative
    text: '[Yves starts walking, eventually arriving at the front of the MIS.]'
    voiceClip: {fileID: 0}
    volume: 1
  - name: Male Voice
    text: "AGHH! S-STOP! I CAN\u2019T SEE YOU GUYS LIKE THAT!"
    voiceClip: {fileID: 0}
    volume: 1
  - name: Yves
    text: It's coming from inside the MIS!
    voiceClip: {fileID: 0}
    volume: 1
  - name: Tala
    text: That voice.. Yves, quick!
    voiceClip: {fileID: 0}
    volume: 1
  - name: Narrative
    text: '[Yves kicks down the door of the MIS and spots a person surrounded by
      enemies.]'
    voiceClip: {fileID: 0}
    volume: 1
  - name: Yves
    text: Hey! Over here!
    voiceClip: {fileID: 0}
    volume: 1
  - name: Tala
    text: "Be careful, Yves.. Something\u2019s wrong with them."
    voiceClip: {fileID: 0}
    volume: 1
  glitchRescueLines:
  - name: Yves
    text: I defeated them all, they look different from the others but I managed.
    voiceClip: {fileID: 0}
    volume: 1
  - name: Glitch
    text: N-no, I-im okay t-thank you so much f-for the help. B-By the w-way, my
      n-name is G-Glitch.
    voiceClip: {fileID: 0}
    volume: 1
  - name: Tala
    text: So, it is him..
    voiceClip: {fileID: 0}
    volume: 1
  - name: Yves
    text: Woah! That is such a cool name, by the way my name is Yves, I'm glad I
      came here and was able to rescue you.
    voiceClip: {fileID: 0}
    volume: 1
  - name: Glitch
    text: 'I-I w-was stuck in t-this place b-because I was working w-when s-suddenly
      the e-enemies attacked and they look o-oddly f-familiar.. '
    voiceClip: {fileID: 0}
    volume: 1
  - name: Glitch
    text: I-I couldn't get o-out of t-this r-room, and t-then suddenly c-creatures
      c-came out of the c-computer monitors and s-started t-to corner m-me, I thought
      I-I was g-gonna d-die right t-then and there!
    voiceClip: {fileID: 0}
    volume: 1
  - name: Yves
    text: "You\u2019re safe now, Glitch!"
    voiceClip: {fileID: 0}
    volume: 1
  - name: Glitch
    text: T-thank you.. P-Please l-let me help y-you i-in return of saving m-me,
      I-I can s-supply y-you with armors t-to i-increase your d-defense.
    voiceClip: {fileID: 0}
    volume: 1
  - name: Yves
    text: WOAH! That would be cool, Glitch! But given your situation right now, you
      need to go. There are people who can help you on the ground floor.
    voiceClip: {fileID: 0}
    volume: 1
  - name: Glitch
    text: O-Okay Y-Yves, T-thank you s-so much for s-saving me, h-here h-have this.
    voiceClip: {fileID: 0}
    volume: 1
  - name: Glitch
    text: (FORESHADOWING) J-just i-in case, I-I think y-you will n-need it.
    voiceClip: {fileID: 0}
    volume: 1
  - name: Yves
    text: I really appreciate it. Thank you, Glitch.
    voiceClip: {fileID: 0}
    volume: 1
  postRescueLines:
  - name: Narrative
    text: '[Yves walks out of the MIS.]'
    voiceClip: {fileID: 0}
    volume: 1
  - name: Yves
    text: "Tala? You\u2019ve been awfully quiet.. Are you well?"
    voiceClip: {fileID: 0}
    volume: 1
  - name: Tala
    text: Just- Yves! Watch out!
    voiceClip: {fileID: 0}
    volume: 1
  - name: Narrative
    text: '[The boss MALWARE attacks! Yves is protected by his new armor.]'
    voiceClip: {fileID: 0}
    volume: 1
  - name: Yves
    text: "I\u2019m really glad that glitch gave me this armor, otherwise I would\u2019ve
      been badly injured.."
    voiceClip: {fileID: 0}
    volume: 1
  - name: Tala
    text: Works like a charm.
    voiceClip: {fileID: 0}
    volume: 1
  - name: Yves
    text: Now, where were we?
    voiceClip: {fileID: 0}
    volume: 1
  finalLines:
  - name: Yves
    text: "(Tired, gasping for air) There\u2026 I took care of that monster\u2026.
      Now, I better get to the next floor and see what's up there."
    voiceClip: {fileID: 0}
    volume: 1
  - name: Tala
    text: You look like a mess.
    voiceClip: {fileID: 0}
    volume: 1
  - name: Yves
    text: "You\u2019re lucky I can\u2019t touch you."
    voiceClip: {fileID: 0}
    volume: 1
  - name: Tala
    text: Scary..
    voiceClip: {fileID: 0}
    volume: 1
