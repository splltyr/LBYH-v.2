--- !u!114 &184528581
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 184528580}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b2c80d98f0f410c4a8b8eb738edf0823, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Scene9
  dialogue: {fileID: 0}
  puzzleUI: {fileID: 1645525633}
  smallFriesGroup: {fileID: 767082975}
  reaperBoss: {fileID: 455669434}
  tableInteractable: {fileID: 1828101306}
  exitDoor: {fileID: 1698816342}
  mainCamera: {fileID: 1708794125}
  bgmSource: {fileID: 0}
  normalBGM: {fileID: 8300000, guid: 73440be1d68d86d4ba0ffbe156fc2ac3, type: 3}
  bossBGM: {fileID: 8300000, guid: 73440be1d68d86d4ba0ffbe156fc2ac3, type: 3}
  introLines:
  - name: Tala
    text: "I\u2019M TIRED!"
    voiceClip: {fileID: 8300000, guid: 48eb339272b134444adf6d336cdd1f16, type: 3}
    volume: 1
  - name: Yves
    text: Just one more floor..
    voiceClip: {fileID: 8300000, guid: b54eb62c0eab464448b3447ea86b5dd3, type: 3}
    volume: 1
  - name: Yves
    text: By the way, these floating books are awesome.
    voiceClip: {fileID: 8300000, guid: cf65a660e26e2944e985d7d0f8f840c8, type: 3}
    volume: 1
  - name: Tala
    text: Not professional.
    voiceClip: {fileID: 8300000, guid: a75773991663ff348856acdf841675f1, type: 3}
    volume: 1
  - name: Yves
    text: This library is too big. How am I gonna find the final source code to stop
      the corruption?
    voiceClip: {fileID: 8300000, guid: cf63d354862c1ad409f899434045761a, type: 3}
    volume: 1
  - name: Tala
    text: "Don\u2019t worry, I\u2019ll be here when you don\u2019t understand things.
      I am sure you can do it, have some faith."
    voiceClip: {fileID: 0}
    volume: 1
  postPuzzleLines:
  - name: Yves
    text: I think I found it!
    voiceClip: {fileID: 8300000, guid: 0a45014a22fdc2b4591b89387260b599, type: 3}
    volume: 1
  - name: Tala
    text: Oooh~ Good job, Yves!
    voiceClip: {fileID: 8300000, guid: efec1e0f49f0c5042bdc7511bcced122, type: 3}
    volume: 1
  - name: Yves
    text: Good thing I have keen eyes, hehe.
    voiceClip: {fileID: 8300000, guid: b9d049d2d7a827c4699e34710fe021b4, type: 3}
    volume: 1
  - name: Tala
    text: Is that.. A Reaper?
    voiceClip: {fileID: 8300000, guid: 9447dcda5c9729d4bbe2edc60f333725, type: 3}
    volume: 1
  - name: Tala
    text: Oh yeah, I forgot about that.
    voiceClip: {fileID: 8300000, guid: e870ae525e71db240ba3b935c695240f, type: 3}
    volume: 1
  - name: Yves
    text: Wait.. WHAT..?
    voiceClip: {fileID: 8300000, guid: 9b33c7d5a0eb8494c9affb25a58a024f, type: 3}
    volume: 1
  - name: Tala
    text: HEHEHE, Goodluck!
    voiceClip: {fileID: 8300000, guid: 43945eb8e74f47c4ba30c77ffaef4320, type: 3}
    volume: 1
  victoryLines:
  - name: Yves
    text: If only I could boil you, Tala.
    voiceClip: {fileID: 8300000, guid: d052a1482482f0943ae8938873ecb218, type: 3}
    volume: 1
  - name: Tala
    text: "Guess what? You can\u2019t, for as I am a spirit."
    voiceClip: {fileID: 8300000, guid: d084741d0fbde844ebfeb36fd7fe6f2e, type: 3}
    volume: 1
  - name: Yves
    text: "\u2026"
    voiceClip: {fileID: 0}
    volume: 1
