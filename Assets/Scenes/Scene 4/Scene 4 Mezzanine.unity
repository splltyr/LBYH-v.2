MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 498868805}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9dc8f4036de00ca4e86b95426973276a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Scene4Manager
  romeScript: {fileID: 1773534530}
  reyaObject: {fileID: 965841699}
  playerObject: {fileID: 151208229}
  misTankBoss: {fileID: 1726699095}
  bossSpawnPoint: {fileID: 674267964}
  romeStopPoint: {fileID: 1229730586}
  romeFinalTalkPoint: {fileID: 69660116}
  reyaStopPoint: {fileID: 374157556}
  reyaExitPoint: {fileID: 2082393937}
  walkSpeed: 3
  nextSceneName: Scene 5
  fadeOverlay: {fileID: 0}
  bgmClip: {fileID: 8300000, guid: 119fc1e7b476960498ae29c12d3022d2, type: 3}
  bgmVolume: 0.102
  dialogueUIObject: {fileID: 1004743394}
  introLines:
  - name: Yves
    text: Huh, the keycard worked to get into the building. Anyway, are the elevators
      worki-
    voiceClip: {fileID: 8300000, guid: a996dc686b77eb54b9e943f8cbb83995, type: 3}
    volume: 1
  - name: ???
    text: "Hey Reya, did you get the food rations back\u2014 ?! WHO ARE YOU?! Wait\u2026
      how did you get that key card?!"
    voiceClip: {fileID: 8300000, guid: 96c8c164cef340649b811a2c91f3b520, type: 3}
    volume: 1
  - name: Yves
    text: "Oh? This? Well actually\u2014"
    voiceClip: {fileID: 8300000, guid: c9073858ac4d7ee42b88a2757e9e9aa0, type: 3}
    volume: 1
  - name: ???
    text: WHO THE HELL ARE YOU?!
    voiceClip: {fileID: 8300000, guid: 96fbb50e0bc4a7346b45500daf1e48a8, type: 3}
    volume: 1
  - name: Yves
    text: Hold on! Let me explain!
    voiceClip: {fileID: 8300000, guid: 444ab3e4e48fb304ea29835ac780e95b, type: 3}
    volume: 1
  - name: ???
    text: I DON'T NEED ANY EXPLANATION FROM YOU MONSTERS! YOU PROBABLY WORK FOR [REDACTED]!
    voiceClip: {fileID: 8300000, guid: a51867005459b774993c17d45e4ad1e0, type: 3}
    volume: 1
  - name: Yves
    text: "What?! Work for who? No! I\u2019m just a student here!"
    voiceClip: {fileID: 0}
    volume: 1
  - name: ???
    text: "LIAR! There\u2019s no students here! Who sent you?!"
    voiceClip: {fileID: 8300000, guid: 8fe76365dbdfc774c80b72ba15f07eb8, type: 3}
    volume: 1
  - name: Yves
    text: "At least listen to me! Cook Re\u2014"
    voiceClip: {fileID: 8300000, guid: a4f7e8b1a0427c240b50b114a9939755, type: 3}
    volume: 1
  reyaConversation:
  - name: Tala
    text: OH! Cook Reya is here! Hang in there, Yves!
    voiceClip: {fileID: 8300000, guid: dfb52ee52baddfe44aa3fa36cb40adaa, type: 3}
    volume: 1
  - name: Cook Reya
    text: WHAT HAPPENED HERE? Oh.. poor kid. You..
    voiceClip: {fileID: 8300000, guid: 47d8f9c7463a9a0439331fd4282b80b7, type: 3}
    volume: 1
  - name: Rome
    text: Reya, you owe me one. I swear.
    voiceClip: {fileID: 8300000, guid: 4eb82df095380be418750fa9323a2d6a, type: 3}
    volume: 1
  - name: Cook Reya
    text: "I sent him here.. And this is what you\u2019ll do to him?!"
    voiceClip: {fileID: 8300000, guid: affa355823a730d49bf3787f6c65e73d, type: 3}
    volume: 1
  - name: Rome
    text: "I didn\u2019t know.."
    voiceClip: {fileID: 8300000, guid: d2dd60b96e24af841aadc10b5b3bc6ad, type: 3}
    volume: 1
  - name: Cook Reya
    text: '*lets out a big sigh* Unbelievable.'
    voiceClip: {fileID: 8300000, guid: 867936dec09ce064ea0f1b20a635222c, type: 3}
    volume: 1
  - name: Cook Reya
    text: Rome, stop screaming at a kid.
    voiceClip: {fileID: 8300000, guid: 2607e609806a82a4eb7b368cf6cf1dda, type: 3}
    volume: 1
  romeApology:
  - name: Rome
    text: "Y-Yes Ma\u2019am.."
    voiceClip: {fileID: 8300000, guid: be965eee4d7ffbe4db11724ca689c840, type: 3}
    volume: 1
  - name: Yves
    text: Rome..?
    voiceClip: {fileID: 8300000, guid: 0bb3e2a09cbb8404a85ba16474d56e87, type: 3}
    volume: 1
  - name: Rome
    text: Sorry about earlier, I was.. A bit too cautious. As an apology, I give
      you this.
    voiceClip: {fileID: 8300000, guid: d546d7633920d1649b948a1329e4c16d, type: 3}
    volume: 1
  - name: Tala
    text: Yeah right.. BLABLABLA
    voiceClip: {fileID: 8300000, guid: e4a8128c124d4f349b197fbe4373f6a2, type: 3}
    volume: 1
  - name: Narrative
    text: '[Player drinks something, now has +5 ATK]'
    voiceClip: {fileID: 0}
    volume: 1
  - name: Rome
    text: "I\u2019m Rome by the way. One of the faculty members here in STI Caloocan.
      I\u2019m one of the IT specialists."
    voiceClip: {fileID: 8300000, guid: 28ab722a9d37a514d921dab55a14dc87, type: 3}
    volume: 1
  bossArrivalLines:
  - name: Rome
    text: "I\u2019m Rome by the way. One of the faculty members here in STI Caloocan.
      I\u2019m one of the IT specialists."
    voiceClip: {fileID: 8300000, guid: 28ab722a9d37a514d921dab55a14dc87, type: 3}
    volume: 1
  - name: Narrative
    text: '[A sudden burst from the faculty entrance shakes the screen, and a shriek
      echoes the room]'
    voiceClip: {fileID: 0}
    volume: 1
  - name: ???
    text: MESSY! MESSY! PAPER EVERYWHERE!
    voiceClip: {fileID: 0}
    volume: 1
  - name: Rome
    text: "Damn\u2026 He came back fast."
    voiceClip: {fileID: 0}
    volume: 1
  - name: Yves
    text: What is that???
    voiceClip: {fileID: 8300000, guid: 361513413f12c844bb56994b979cf194, type: 3}
    volume: 1
  - name: Rome
    text: A corrupted faculty member. He was once a part of the MIS, something went
      wrong and he fused with the servers.
    voiceClip: {fileID: 8300000, guid: 2bac4a4e0cb956849af62a6a5464a1aa, type: 3}
    volume: 1
  - name: Rome
    text: "He was once a friend of mine\u2026 "
    voiceClip: {fileID: 0}
    volume: 1
  - name: Yves
    text: You mean, that was once a person?
    voiceClip: {fileID: 8300000, guid: 5c99b69d1c624674fa7b08d6c68c6d2c, type: 3}
    volume: 1
  - name: Rome
    text: "Yep\u2026 Before that damn guy turned everything upside down."
    voiceClip: {fileID: 8300000, guid: f8cb42bd11f35f74ba96dfc9d5b21c04, type: 3}
    volume: 1
  - name: Yves
    text: "By that guy\u2026 Do you mean\u2026?"
    voiceClip: {fileID: 8300000, guid: 3b1a5f0982b43074fa7effc39945b5a0, type: 3}
    volume: 1
  - name: Rome
    text: '[REDACTED]. Who else? '
    voiceClip: {fileID: 8300000, guid: 28175727c7fd92e4f8a0292ac5dde9aa, type: 3}
    volume: 1
  - name: Yves
    text: "I didn\u2019t hear y-"
    voiceClip: {fileID: 8300000, guid: e84463f325ac391459f984db4fb3c642, type: 3}
    volume: 1
  - name: Tala
    text: Yves! Be cautious.
    voiceClip: {fileID: 8300000, guid: 993ede15280f9c443916e940b34fb9b2, type: 3}
    volume: 1
  bossDefeatedLines:
  - name: Rome
    text: Not bad, kid. I see potential.
    voiceClip: {fileID: 8300000, guid: adfd61fa5675d33459acecc7378a152a, type: 3}
    volume: 1
  - name: Yves
    text: Uh.. Thanks. Where are you headed now?
    voiceClip: {fileID: 8300000, guid: 01b2247be005dcf4a9f47d38c2044079, type: 3}
    volume: 1
  - name: Rome
    text: I need to assist Reya with the food rations. The corruption is starting
      to spread throughout the STEM Laboratory in the 2nd and 4th floors. We need
      to evacuate civilians still in this building.
    voiceClip: {fileID: 8300000, guid: b9d64ec313f866b4b88c8194e43e8a21, type: 3}
    volume: 1
  - name: Tala
    text: "Oooo! That\u2019s great, we\u2019ll be going there anyway!"
    voiceClip: {fileID: 8300000, guid: 7761213ed34eca141882de64343fcbf9, type: 3}
    volume: 1
  - name: Yves
    text: I can help. I need to go up too.
    voiceClip: {fileID: 8300000, guid: 68f12e0381e19bd4489916b02b4fec69, type: 3}
    volume: 1
  - name: Rome
    text: Why?
    voiceClip: {fileID: 8300000, guid: 4791ec6474492384594aed02acdffeb7, type: 3}
    volume: 1
  - name: Tala
    text: "You can\u2019t tell him, Yves.. [GLITCHY VOICE]"
    voiceClip: {fileID: 8300000, guid: 205df32f5e13d07488557baf4da8eff1, type: 3}
    volume: 1
  - name: Yves
    text: "I\u2026 don\u2019t know actually."
    voiceClip: {fileID: 8300000, guid: 7dac62a3189dcd34aa4789c5fd28a1ce, type: 3}
    volume: 1
  - name: Rome
    text: "You\u2019re a strange kid, aren\u2019t you? Welp, here\u2019s the keycard
      to pass through the 2nd floor."
    voiceClip: {fileID: 8300000, guid: c095a940168ecf84bbc1f869bcda04a8, type: 3}
    volume: 1
  - name: Rome
    text: "Be careful, sneaks roam around the place. Things are a lot worse up there.
      It\u2019s like a different place."
    voiceClip: {fileID: 8300000, guid: fcadbb1de2a35cc4bb81c0ba4c17ce9f, type: 3}
    volume: 1
  - name: Tala
    text: "Oop- He\u2019s right."
    voiceClip: {fileID: 8300000, guid: 0edb173df948e9d419ec7f4251d1db62, type: 3}
    volume: 1
  - name: Yves
    text: Okay, thanks.
    voiceClip: {fileID: 8300000, guid: 38eba52c9b9720741819d2fd4f87b6f0, type: 3}
    volume: 1
  - name: Rome
    text: "If ever you need some leveling up, just come here. I\u2019ll invest more
      if you need. And you might come across Dave. I think he\u2019ll be able to
      help you too."
    voiceClip: {fileID: 8300000, guid: 37e74bb6fb2858647a2abc19b982f9ba, type: 3}
    volume: 1
  - name: Yves
    text: Will do, see you Sir Rome.
    voiceClip: {fileID: 8300000, guid: 5f3731d0ced8f3b4e9bfb98378186f66, type: 3}
    volume: 1
  - name: Rome
    text: Take care kid.
    voiceClip: {fileID: 8300000, guid: de3c4d34c57a47c468b3a13b2dcf823d, type: 3}
    volume: 1
  - name: Tala
    text: "He\u2019s a good man after all.."
    voiceClip: {fileID: 8300000, guid: 22d35eb5ad83ab842873cc4fc6f0ab8e, type: 3}
    volume: 1
  - name: Yves
    text: Why did you say that I can't tell Sir Rome? Tell him what, exactly?
    voiceClip: {fileID: 8300000, guid: bf47800422937b84c8bec9f6634f30e8, type: 3}
    volume: 1
  - name: Tala
    text: "\u2026"
    voiceClip: {fileID: 0}
    volume: 1
  - name: Narrative
    text: "[Tala stays quiet, as she knows that Yves couldn\u2019t remember anything
      because of the time loop.]"
    voiceClip: {fileID: 0}
    volume: 1
