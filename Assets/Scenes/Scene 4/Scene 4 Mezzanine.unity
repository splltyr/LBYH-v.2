MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1773534528}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 92ed3b06c61eb7c4d9658df97161d774, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::RomeNPC
  walkSpeed: 16
  walkToPoint: {fileID: 1229730586}
  dialogueBox: {fileID: 1004743394}
  textDisplay: {fileID: 1670141712}
  nameDisplay: {fileID: 0}
  typeSpeed: 0.04
  initialEncounter:
  - characterName: Yves
    sentence: 'Yves: Huh, the keycard worked to get into the building. Anyway, are
      the elevators worki-

'
  - characterName: Rome
    sentence: "???: Hey Reya, did you get the food rations back\u2014 ?! \r\nWHO
      ARE YOU?! Wait\u2026 how did you get that key card?!\r\n"
  - characterName: Yves
    sentence: "Yves: Oh? This? Well actually\u2014"
  - characterName: Rome
    sentence: WHO THE HELL ARE YOU?! I don't need explanations from you monsters!
  - characterName: Rome
    sentence: 'Yves: Hold on! Let me explain!

'
  - characterName: Yves
    sentence: 'Staff: I DON''T NEED ANY EXPLANATION FROM YOU MONSTERS! YOU PROBABLY
      WORK FOR [REDACTED]!'
  - characterName: Cook Reya
    sentence: "Yves: What?! Work for who? No! I\u2019m just a student here!\r\n"
  - characterName: Cook Reya
    sentence: "???: LIAR! There\u2019s no students here! Who sent you?! "
  - characterName: Cook Reya
    sentence: "Yves: At least listen to me! Cook Re\u2014 "
  - characterName: Cook Reya
    sentence: '???: OH! Cook Reya is here! Hang in there, Yves!

'
  - characterName: Cook Reya
    sentence: 'Cook Reya: WHAT IS ALL THIS SCREAMING? '
  - characterName: Cook Reya
    sentence: '???: Reya, you owe me one. I swear. '
  - characterName: Cook Reya
    sentence: "???: Oh look, it\u2019s Cook Reya! "
  - characterName: Cook Reya
    sentence: "Cook Reya: I sent him here.. And this is what you\u2019ll do to him?! "
  - characterName: Cook Reya
    sentence: 'Cook Reya: *lets out a big sigh* Unbelievable. '
  - characterName: Cook Reya
    sentence: 'Cook Reya: Rome, stop screaming at a kid. '
  - characterName: Cook Reya
    sentence: "Rome: Y-Yes Ma\u2019am.. "
  - characterName: Cook Reya
    sentence: 'Yves: Rome..? '
  - characterName: Cook Reya
    sentence: 'Rome: Sorry about earlier, I was.. A bit too cautious. As an apology,
      I give you this. '
  - characterName: Cook Reya
    sentence: '???: Yeah right.. BLABLABLA (Player now has +5 ATK!)

'
  - characterName: Cook Reya
    sentence: "Rome: I\u2019m Rome by the way. One of the faculty members here in
      STI Caloocan. I\u2019m one of the IT specialists.\r\n"
  afterAwakening:
  - characterName: Rome
    sentence: Sorry about earlier, I was.. a bit too cautious. As an apology, I give
      you this.
  - characterName: Tala
    sentence: (GLITCH) Yeah right.. BLABLABLA.
  - characterName: Yves
    sentence: (Yves drinks the mystery liquid... +5 ATK Gained!)
  - characterName: Rome
    sentence: "I\u2019m Rome, one of the IT specialists here in STI Caloocan. I try
      to help people survive this hell."
  - characterName: Rome
    sentence: My skills let me tweak data here and there. Let's see if my investment
      in you was a good gamble.
  merchantLines:
  - characterName: Rome
    sentence: "Not bad, kid. Here\u2019s the keycard for the 2nd floor. Be careful,
      things are worse up there."
  - characterName: Yves
    sentence: Thanks. Sir Rome, what exactly do you do here?
  - characterName: Rome
    sentence: I steal data to help civilians evacuate. Head for the STEM Lab, but
      watch out for sneaks.
  - characterName: Yves
    sentence: (To Tala) Why did you say I can't tell him... tell him what exactly?
  - characterName: Tala
    sentence: ...
