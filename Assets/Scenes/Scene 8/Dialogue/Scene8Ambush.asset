  lines:
  - name: Narrative
    text: "[Enemies appear: File Flingers throwing sharp folder-like projectiles.]"
    voiceClip: {fileID: 0}
  - name: Tala
    text: "YVES! BEHIND YOU!"
    voiceClip: {fileID: 0}
  - name: Narrative
    text: "[Yves is startled by Tala out of nowhere then he dodges the attack to counter attack.]"
